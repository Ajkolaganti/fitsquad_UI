# --- FitSquad UI (Next.js) ---

# Same-origin API proxy (recommended — avoids CORS). Do not use a full http URL here
# unless you intentionally want direct calls and CORS configured on the API.
# Must be the API origin only (e.g. http://localhost:4000), never a path like .../auth/register.
NEXT_PUBLIC_API_URL=/api-proxy

# Target your Express/FitSquad API (used only by Next.js rewrites, not exposed to the browser).
# Use https:// for deployed hosts (e.g. Railway). Use http://localhost:4000 only when the API runs locally.
# Example (Railway):
#   API_PROXY_TARGET=https://your-service.up.railway.app
# Example (local):
#   API_PROXY_TARGET=http://localhost:4000
API_PROXY_TARGET=http://localhost:4000

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps JavaScript API — enable “Maps JavaScript API” + “Places API” on the key; restrict by HTTP referrer.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBZczRXdetIg8Ki0jBlzRoPqgLevQfAwHU

# Supabase (browser) — Auth: email/password + email verification links
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
