# --- FitSquad UI (Next.js) ---

# Same-origin API proxy (recommended — avoids CORS). Do not use a full http URL here
# unless you intentionally want direct calls and CORS configured on the API.
# Must be the API origin only (e.g. http://localhost:4000), never a path like .../auth/register.
NEXT_PUBLIC_API_URL=/api-proxy

# Target your Express/FitSquad API (used only by Next.js rewrites, not exposed to the browser).
# Local:
API_PROXY_TARGET=http://localhost:4000
# Production (e.g. Vercel): set to your real API base, e.g. https://api.fitsquad.fit

NEXT_PUBLIC_SITE_URL=https://fitsquad.fit

# Supabase (browser) — Auth: email/password + email verification links
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
